rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Song Validation Helper
    function isValidSong(data) {
      return data.keys().hasAll(['id', 'title', 'artist', 'chords']) &&
             data.keys().size() <= 5 &&
             data.id is string && isValidId(data.id) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 256 &&
             data.artist is string && data.artist.size() > 0 && data.artist.size() <= 256 &&
             data.chords is string && data.chords.size() <= 1048576; // 1MB limit
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Setlists Collection
    match /setlists/{setlistId} {
      allow read, write: if true;
    }

    // Songs Collection
    match /songs/{songId} {
      allow read, list: if true;
      allow write: if request.auth != null && request.auth.token.email == 'eliseortega20@gmail.com';
    }

    // Events Collection
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Songs Collection V2
    match /songs_v2/{songId} {
      allow read, list: if true;
      allow write: if true;
    }

    // Songs Collection V4
    match /songs_v4/{songId} {
      allow read, list: if true;
      allow write: if true;
    }
  }
}
